{
  "name": "marque",
  "version": "1.0.0",
  "description": "Sign an outbound agent message with a secp256k1 wallet key and verify which https origin sent it — no shared secret.",
  "type": "module",
  "license": "MIT",
  "main": "./dist/marque.js",
  "types": "./dist/marque.d.ts",
  "exports": {
    ".": {
      "types": "./dist/marque.d.ts",
      "import": "./dist/marque.js"
    }
  },
  "bin": {
    "marque": "./dist/bin/marque.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc && rm -f dist/marque.test.*",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test marque.test.ts",
    "marque": "tsx bin/marque.ts"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "viem": "^2.23.0"
  },
  "devDependencies": {
    "@types/node": "^22",
    "tsx": "^4",
    "typescript": "^5"
  }
}
