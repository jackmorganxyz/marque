{
  "name": "marque",
  "version": "1.0.0",
  "description": "Sign an outbound agent message with a secp256k1 wallet key and verify which https origin sent it — no shared secret.",
  "type": "module",
  "license": "MIT",
  "author": "Jack Morgan <contact@jackmorgan.xyz>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jackmorganxyz/marque.git"
  },
  "bugs": "https://github.com/jackmorganxyz/marque/issues",
  "homepage": "https://github.com/jackmorganxyz/marque#readme",
  "keywords": ["agent", "signing", "identity", "verify", "well-known", "eip-191", "secp256k1", "a2a"],
  "sideEffects": false,
  "main": "./dist/marque.js",
  "types": "./dist/marque.d.ts",
  "exports": {
    ".": {
      "types": "./dist/marque.d.ts",
      "import": "./dist/marque.js"
    },
    "./x": {
      "types": "./dist/x.d.ts",
      "import": "./dist/x.js"
    }
  },
  "bin": {
    "marque": "./dist/bin/marque.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc && rm -f dist/*.test.*",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test marque.test.ts x.test.ts",
    "marque": "tsx bin/marque.ts",
    "prepare": "npm run build",
    "prepublishOnly": "npm test"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@noble/curves": "^1.9.7",
    "@noble/hashes": "^1.8.0"
  },
  "devDependencies": {
    "@types/node": "^22",
    "tsx": "^4",
    "typescript": "^5"
  }
}
